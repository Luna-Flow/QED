///|
/// Blackbox test package: full `using` union (main `alias.mbt` is not in scope here).
using @kernel {
  type KernelState,
  type Term,
  type Thm,
  type HolType,
  type SigError,
  type LogicError,
  type ExtensionCert,
  empty_kernel_state,
  bool_ty,
  fun_ty,
  mk_tyvar,
  ty_eq,
  ks_add_const,
  ks_lookup_const,
  ks_definition_theorem,
  ks_mk_const,
  ks_define_const_thm,
  ks_push_scope,
  mk_comb,
  mk_abs,
  mk_const,
  mk_var,
  mk_eq,
  dest_comb,
  dest_abs,
  dest_const,
  dest_eq,
  term_alpha_eq,
  term_logical_eq,
  thm_concl,
  thm_hyps,
  thm_hyp_count,
  type_of,
  assume_checked,
  add_assum_checked,
  refl_checked,
  trans_checked,
  mk_comb_rule_checked,
  abs_rule_checked,
  beta_rule_checked,
  eq_mp_checked,
  deduct_antisym_rule_checked,
  inst_type,
  inst_checked,
  ks_register_type_definition,
