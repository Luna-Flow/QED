theorem constructive_diamond
    (p : bool) (q : bool) (r : bool) (s : bool)
    : ⊢ (p -> q) -> (q -> r) -> (p -> s) -> p -> (r ∧ s) ∧ (T ∨ r) := by
    intro hpq
    intro hqr
    intro hps
    intro hp
    split {
      split {
        apply hqr
        apply hpq
        exact hp
      } {
        apply hps
        exact hp
      }
    } {
      right {
      apply hqr
      apply hpq
      exact hp
    }
  }
qed